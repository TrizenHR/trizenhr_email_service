# =============================================================================
# TrizenHR Email Service — copy to .env (local) or CapRover App Configs (prod)
# SERVICE_AUTH_TOKEN must match trizenhr_backend EMAIL_SERVICE_AUTH_TOKEN
# =============================================================================

NODE_ENV=development
PORT=4007

# MongoDB (email logs) — can share Atlas cluster; use a dedicated DB name
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=trizenhr_email

# Auth — same value on backend as EMAIL_SERVICE_AUTH_TOKEN (min 32 chars)
SERVICE_AUTH_TOKEN=your_super_secret_token_min_32_chars_long_12345

EMAIL_PROVIDER=smtp

# -----------------------------------------------------------------------------
# PRIMARY SMTP — Company Admin / new organization invites
# From: support@trizenhr.com
# Microsoft 365: SMTP_USER MUST equal EMAIL_FROM_ADDRESS
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@trizenhr.com
SMTP_PASS=your_trizenhr_mailbox_app_password

EMAIL_FROM_ADDRESS=support@trizenhr.com
EMAIL_FROM_NAME=TrizenHR Support
EMAIL_REPLY_TO=support@trizenhr.com

# -----------------------------------------------------------------------------
# ORG SMTP — HR / Manager / Employee role invitations
# From: support@trizenventures.com
# -----------------------------------------------------------------------------
SMTP_USER_ORG=support@trizenventures.com
SMTP_PASS_ORG=your_trizenventures_mailbox_app_password
# Optional overrides (default to primary SMTP_HOST / SMTP_PORT)
# SMTP_HOST_ORG=smtp.office365.com
# SMTP_PORT_ORG=587
EMAIL_FROM_ADDRESS_ORG=support@trizenventures.com
EMAIL_FROM_NAME_ORG=TrizenVentures

# TrizenHR app URLs (used in some legacy templates)
WEB_APP_URL=https://trizenhr.com
MOBILE_APP_DEEP_LINK=trizenhr://

# Internal notify when an org is created (defaults to EMAIL_FROM_ADDRESS)
# TRIZEN_PLATFORM_NOTIFY_EMAIL=support@trizenhr.com
TRIZEN_SUPPORT_EMAIL=support@trizenventures.com

LOG_LEVEL=info

# Optional
# LOGO_URL=https://your-cdn/logo.png
# CORS_ORIGIN=https://trizenhr.com,https://trizenhr-backend.llp.trizenventures.com
