# Server
NODE_ENV=development
PORT=4007

# MongoDB
MONGODB_URI=mongodb://localhost:27017/extrahand
MONGODB_DB=extrahand

# Service Authentication (must match trizenhr_backend EMAIL_SERVICE_AUTH_TOKEN)
SERVICE_AUTH_TOKEN=your_super_secret_token_min_32_chars_long_12345

# Email Provider (smtp, sendgrid, or ses)
EMAIL_PROVIDER=smtp

# ===== SMTP Configuration (Microsoft/Outlook) =====
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@extrahand.in
SMTP_PASS=your_microsoft_password_or_app_password

# ===== SendGrid (Optional) =====
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# ===== AWS SES (Optional) =====
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx

# Email Settings — platform (company admin / org invites)
EMAIL_FROM_ADDRESS=support@trizenhr.com
EMAIL_FROM_NAME=TrizenHR Support
EMAIL_REPLY_TO=support@trizenhr.com

# Organisation sender (HR / manager / employee invites)
SMTP_USER_ORG=support@trizenventures.com
SMTP_PASS_ORG=your_app_password_here
EMAIL_FROM_ADDRESS_ORG=support@trizenventures.com
EMAIL_FROM_NAME_ORG=TrizenVentures

# Application URLs
WEB_APP_URL=https://extrahand.in
MOBILE_APP_DEEP_LINK=extrahand://

# Optional: internal notify inbox (defaults to EMAIL_FROM_ADDRESS)
# TRIZEN_PLATFORM_NOTIFY_EMAIL=support@trizenhr.com
# Legacy field from backend (org staff); not used as From for company-admin invites
TRIZEN_SUPPORT_EMAIL=support@trizenventures.com

# User Service (for notification preference checks before sending task emails)
# Required in production when services run in separate containers
USER_SERVICE_URL=http://localhost:4001

# Logging
LOG_LEVEL=info

# CORS (optional, comma-separated)
# CORS_ORIGIN=https://admin.extrahand.in,https://app.extrahand.in

# Optional: used only if a caller omits platformName on POST /admin-invite
# DEFAULT_ADMIN_INVITE_PLATFORM_NAME=Partner Onboarding Platform
